{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agy-swarms.local/schemas/local-graph-preflight-v1.schema.json",
  "title": "agy-swarms local graph preflight v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "node_count",
    "edge_count",
    "role_counts",
    "command_node_ids",
    "root_nodes",
    "leaf_nodes",
    "dependency_fan_out",
    "commands_executed"
  ],
  "properties": {
    "status": {"type": "string", "enum": ["valid"]},
    "node_count": {"type": "integer", "minimum": 0},
    "edge_count": {"type": "integer", "minimum": 0},
    "role_counts": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 0}
    },
    "command_node_ids": {"type": "array", "items": {"type": "string"}},
    "root_nodes": {"type": "array", "items": {"type": "string"}},
    "leaf_nodes": {"type": "array", "items": {"type": "string"}},
    "dependency_fan_out": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dependencies", "dependents", "fan_in", "fan_out"],
        "properties": {
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "dependents": {"type": "array", "items": {"type": "string"}},
          "fan_in": {"type": "integer", "minimum": 0},
          "fan_out": {"type": "integer", "minimum": 0}
        }
      }
    },
    "commands_executed": {"type": "boolean", "const": false}
  }
}
